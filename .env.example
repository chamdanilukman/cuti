# Salin file ini menjadi .env lalu isi nilainya.
# JANGAN pernah menaruh SERVICE ROLE KEY di sini — variabel VITE_ ter-bundle ke browser.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# cPanel Configuration
VITE_CPANEL_UPLOAD_URL=https://your-domain/api/upload.php
VITE_CPANEL_DELETE_URL=https://your-domain/api/delete.php

# UI Version
# 'v1' = UI lama (navigasi section-based, tanpa grafik dashboard)
# 'v2' = UI baru (React Router + Chart.js dashboard + Kalender Kerja)
VITE_DEFAULT_UI_VERSION=v2
